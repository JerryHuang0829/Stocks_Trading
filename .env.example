# Telegram Bot 設定
# 1. 在 Telegram 搜尋 @BotFather，發送 /newbot 建立 Bot，取得 Token
# 2. 搜尋 @userinfobot，發送任意訊息，取得你的 Chat ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# FinMind API Token（可選，免費註冊可提高 API 額度）
# 註冊：https://finmindtrade.com/
# 免費版 600 req/hr，多 token 可輪替使用（preflight 依序嘗試）
FINMIND_TOKEN=
FINMIND_TOKEN2=
FINMIND_TOKEN3=

# 資料快取目錄（必填，絕對路徑）
# 避免 legacy `C:\app\data\cache\` 誤解析
# 建議放在 SSD 上以加速 pickle 讀寫（cache 約 2-5 GB）
DATA_CACHE_DIR=
